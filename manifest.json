{
  "manifest_version": 3,
  "version": "1.1.0",
  "name": "__MSG_extensionName__",
  "default_locale": "en",
  "description": "__MSG_extensionDesc__",
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "tabs",
    "clipboardRead",
    "clipboardWrite",
    "notifications",
    "webRequest",
    "declarativeNetRequest",
    "downloads"
  ],
  "host_permissions": [
    "*://api.uid.one/*",
    "*://*.uid.one/*",
    "*://localhost/*",
    "*://127.0.0.1/*",
    "file:///*"
  ],
  "background": {
    "service_worker": "src/background/index.ts"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "js": ["src/content/index.ts"]
    },
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "js": ["src/main-world.ts"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "wasm/*",
        "models/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "identity@uid.one",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
