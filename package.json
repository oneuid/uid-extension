{
  "name": "uid-extension-client",
  "private": true,
  "version": "1.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:firefox": "tsc && TARGET=firefox vite build",
    "zip:chrome": "cd dist/chrome && zip -r ../../uid-link-chrome.zip .",
    "zip:firefox": "cd dist/firefox && zip -r ../../uid-link-firefox.zip .",
    "build:publish": "npm run build && npm run build:firefox && npm run zip:chrome && npm run zip:firefox",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/qrcode": "^1.5.6",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-web-extension": "^4.5.1"
  },
  "dependencies": {
    "@signpdf/signpdf": "^3.3.0",
    "@signpdf/utils": "^3.3.0",
    "@types/node-forge": "^1.3.14",
    "node-forge": "^1.4.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4"
  }
}
